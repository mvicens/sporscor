{
	"compilerOptions": {
		// File Layout
		"rootDir": "./src",
		"outDir": "./dist",

		// Environment Settings
		"module": "esnext",
		"target": "es2022",

		// Other Outputs
		"declaration": true,

		// Recommended Options
		"strict": true,

		"moduleResolution": "bundler"
	},
	"include": [
		"src"
	]
}